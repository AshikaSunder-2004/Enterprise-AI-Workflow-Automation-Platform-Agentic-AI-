{
  "name": "aiwf-backend",
  "version": "1.0.0",
  "description": "Enterprise AI Workflow Automation Platform — Backend",
  "main": "dist/api/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/api/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/queue/worker.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "start:worker": "node dist/queue/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "test": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:all": "jest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@prisma/client": "^5.22.0",
    "ajv": "^8.17.1",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonschema": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "p-limit": "^6.2.0",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "ws": "^8.18.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/json-schema": "^7.0.15",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
