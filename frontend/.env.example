# 🌐 Production API & WebSocket Configuration (Optional)
# If left blank, API requests will default to '/api' (useful for dev proxies/relative URLs).
# For production hosting (like Vercel), set these to your deployed backend URLs.

# The HTTP URL of your deployed Express backend API (e.g., https://api.my-workflow-app.com)
VITE_API_URL=

# The WebSocket URL of your deployed Express backend API (e.g., wss://api.my-workflow-app.com/ws)
VITE_WS_URL=
